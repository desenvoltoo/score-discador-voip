generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
enum Role { ADMIN SUPERVISOR OPERADOR }
enum CampaignStatus { RASCUNHO ATIVA PAUSADA ENCERRADA }
enum LeadStatus { NOVO EM_FILA LIGANDO ATENDIDO NAO_ATENDEU OCUPADO NUMERO_INVALIDO CAIXA_POSTAL RETORNO INTERESSADO SEM_INTERESSE MATRICULADO NAO_LIGAR_NOVAMENTE ERRO_CHAMADA }
enum CallStatus { CREATED STARTED RINGING ANSWERED COMPLETED FAILED CANCELED }
model User { id String @id @default(cuid()) name String email String @unique passwordHash String role Role extension String? active Boolean @default(true) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt campaigns Campaign[] @relation("ResponsibleCampaigns") leads Lead[] @relation("OperatorLeads") calls CallAttempt[] auditLogs AuditLog[] }
model Campaign { id String @id @default(cuid()) name String description String? status CampaignStatus @default(RASCUNHO) responsibleId String? responsible User? @relation("ResponsibleCampaigns", fields:[responsibleId], references:[id]) allowedCallStart String @default("08:00") allowedCallEnd String @default("18:00") maxAttemptsPerLead Int @default(3) minIntervalMinutes Int @default(60) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt leads Lead[] calls CallAttempt[] imports ImportLog[] }
model Lead { id String @id @default(cuid()) name String phoneNormalized String phoneOriginal String cpf String? email String? course String? origin String? notes String? campaignId String campaign Campaign @relation(fields:[campaignId], references:[id], onDelete:Cascade) operatorId String? operator User? @relation("OperatorLeads", fields:[operatorId], references:[id]) status LeadStatus @default(NOVO) doNotCall Boolean @default(false) callbackAt DateTime? lastAttemptAt DateTime? attemptsCount Int @default(0) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt calls CallAttempt[] @@unique([campaignId, phoneNormalized]) @@index([phoneNormalized]) }
model CallAttempt { id String @id @default(cuid()) leadId String lead Lead @relation(fields:[leadId], references:[id], onDelete:Cascade) campaignId String campaign Campaign @relation(fields:[campaignId], references:[id]) operatorId String operator User @relation(fields:[operatorId], references:[id]) startedAt DateTime? endedAt DateTime? durationSeconds Int? provider String providerCallId String? status CallStatus @default(CREATED) finalDisposition LeadStatus? notes String? errorMessage String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model ImportLog { id String @id @default(cuid()) campaignId String campaign Campaign @relation(fields:[campaignId], references:[id], onDelete:Cascade) fileName String totalRead Int totalImported Int duplicates Int invalid Int blocked Int createdById String? createdAt DateTime @default(now()) }
model DoNotCall { id String @id @default(cuid()) phoneNormalized String @unique reason String? blockedById String? blockedAt DateTime @default(now()) }
model AuditLog { id String @id @default(cuid()) userId String? user User? @relation(fields:[userId], references:[id]) action String entity String? entityId String? metadata Json? createdAt DateTime @default(now()) }
model VoipConfig { id String @id @default(cuid()) provider String @default("mock") asteriskHost String? asteriskPort Int? asteriskUsername String? asteriskContext String? asteriskTrunk String? operatorPrefix String? updatedAt DateTime @updatedAt }
